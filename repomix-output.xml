def collect_telemetry_features(logger):
    provider, asn = logger.get_network_info_cached()
    tcp_success = 0
    latencies = []
    total_tests = len(TEST_TARGETS)

    for name, url in TEST_TARGETS.items():
        domain = url.split("://")[1].split("/")[0]
        ip = get_real_ip_via_doh(domain)
        if not ip:
            continue
        
        start = time.time()
        try:
            import socket
            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            s.settimeout(2.0)
            s.connect((ip, 443))
            latencies.append(time.time() - start)
            tcp_success += 1
            s.close()
        except Exception:
            pass

    avg_lat = sum(latencies) / len(latencies) if latencies else 2.5
    packet_loss = 1.0 - (tcp_success / total_tests)

    return {
        "provider": provider,
        "asn": asn,
        "connect_latency": avg_lat,
        "packet_loss": packet_loss
    }

