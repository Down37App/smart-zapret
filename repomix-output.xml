# -*- coding: utf-8 -*-
import os, sys, time, re, subprocess, zipfile, shutil
from core.diagnostics import (
    is_admin, get_active_interfaces, set_custom_dns, restore_dns,
    get_real_ip_via_doh, test_target_impersonated, detect_tspu_hop,
    classify_blocking_symptoms, TEST_TARGETS
)
from core.telemetry import TelemetryLogger

import zapret_helper as zh

DISCORD_TARGET_WEIGHTS = {"Discord Website": 25.0, "Discord Gateway": 25.0, "Discord CDN": 25.0, "Discord Updates": 25.0}
TEST_TARGETS["Discord CDN"] = "https://discordcdn.com"
TEST_TARGETS["Discord Updates"] = "https://updates.discord.com"

def normalize_path(path):
    return os.path.abspath(path).replace("\\", "/")

def get_zapret_version(winws_path):
    try:
        res = subprocess.run(f"\"{winws_path}\" --help", shell=True, capture_output=True, text=True, errors='ignore')
        first_line = res.stdout.split('\n')[0]
        match = re.search(r'winws v([0-9a-zA-Z\.]+)', first_line)
        if match: return match.group(1)
    except: pass
    return "1.9.9c"

def discover_engine_path():
    base_dir = "zapret_extracted"
    for root, dirs, files in os.walk(base_dir):
        if "winws.exe" in files:
            if os.path.basename(root).lower() == "bin":
                return normalize_path(os.path.join(root, "winws.exe"))
    return "winws.exe"

def flush_dns_cache():
    try:
        subprocess.run("ipconfig /flushdns", shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        print("[*] Кэш DNS успешно очищен (ipconfig /flushdns).")
    except: pass

def disable_virtual_adapters():
    print("[*] Сетевой фильтр: временное отключение WSL/Radmin во избежание конфликтов...")
    try:
        subprocess.run('powershell -Command "Disable-NetAdapter -Name *WSL* -Confirm:$false"', shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.run('powershell -Command "Disable-NetAdapter -Name *Default* -Confirm:$false"', shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.run('powershell -Command "Disable-NetAdapter -Name *Radmin* -Confirm:$false"', shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        print("[+] Конфликтные адаптеры успешно отключены.")
    except Exception as e: print(f"[-] Не удалось отключить адаптеры: {e}")

def enable_virtual_adapters():
    print("\n[*] Сетевой фильтр: восстановление работы WSL/Radmin...")
    try:
        subprocess.run('powershell -Command "Enable-NetAdapter -Name *WSL* -Confirm:$false"', shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.run('powershell -Command "Enable-NetAdapter -Name *Default* -Confirm:$false"', shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.run('powershell -Command "Enable-NetAdapter -Name *Radmin* -Confirm:$false"', shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        print("[+] Все виртуальные адаптеры включены обратно.")
    except Exception: pass

def get_supported_options(engine_path):
    try:
        res = subprocess.run(f"\"{engine_path}\" --help", shell=True, capture_output=True, text=True, errors='ignore')
        options = set(re.findall(r'--[a-zA-Z0-9\-]+', res.stdout))
        return options, res.stdout.lower()
    except: return set(), ""

def validate_strategy_for_engine(strategy_cmd, supported_options, help_text):
    words = strategy_cmd.split()
    valid_words, skip_next = [], False
    for i, word in enumerate(words):
        if skip_next:
            skip_next = False
            continue
        if word.startswith("--"):
            opt_name = word.split("=")[0]
            if opt_name not in supported_options:
                if "=" not in word and (i + 1 < len(words)) and not words[i+1].startswith("--"):
                    skip_next = True
                continue
            if "--dpi-desync-fake-tls-mod" in word:
                val = word.split("=")[1] if "=" in word else ""
                if "rnd" in val and "rnd" not in help_text:
                    word = "--dpi-desync-fake-tls-mod=padded"
            if "--dpi-desync-split-pos" in word:
                val = word.split("=")[1] if "=" in word else ""
                if "mame" in val and sys.platform == "win32":
                    word = "--dpi-desync-split-pos=sniext"
        valid_words.append(word)
    return " ".join(valid_words)

def populate_discord_lists(bat_dir):
    lists_dir = normalize_path(os.path.join(bat_dir, "lists"))
    os.makedirs(lists_dir, exist_ok=True)
    discord_domains = [
        "discord.com", "gateway.discord.gg", "discordapp.com", "discordapp.net", "discord.gg", "discord.media", 
        "discordcdn.com", "discordapi.com", "dis.gd", "discord.co", "updates.discord.com", "status.discord.com", 
        "discordstatus.com", "media.discordapp.net", "images-ext-1.discordapp.net", "dl2.discordapp.net", "stable.dl2.discordapp.net"
    ]
    list_discord_path = normalize_path(os.path.join(lists_dir, "list-discord.txt"))
    try:
        with open(list_discord_path, 'w', encoding='utf-8') as f: f.write("\n".join(discord_domains) + "\n")
        print("[*] Списки доменов: файл list-discord.txt успешно наполнен всеми 17 служебными доменами.")
    except Exception as e: print(f"[-] Не удалось записать list-discord.txt: {e}")

def write_dedicated_discord_bat(bat_dir, strategy_cmd, strategy_name):
    """Генерирует выделенный BAT-файл только под Discord с временной установкой DNS на ВСЕХ активных физических адаптерах."""
    bat_path = normalize_path(os.path.join(bat_dir, "discord_custom.bat"))

    content = f"""@echo off
chcp 65001 > nul
cd /d "%~dp0"

:: Проверка прав Администратора
net session >nul 2>&1 || (echo [!] Ошибка: Пожалуйста, запустите этот BAT-файл от имени Администратора! & pause & exit /b)

set "BIN=%~dp0bin\\"
set "LISTS=%~dp0lists\\"
cd /d %BIN%

echo [*] Подготовка сети: временная установка DNS 1.1.1.1 на всех активных адаптерах...
powershell -Command "Get-NetIPInterface -ConnectionState Connected -AddressFamily IPv4 | Where-Object {{ $_.InterfaceAlias -notlike '*Loopback*' }} | ForEach-Object {{ Set-DnsClientServerAddress -InterfaceAlias $_.InterfaceAlias -ServerAddresses ('1.1.1.1', '8.8.8.8') }}"
