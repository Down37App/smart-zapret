# -*- coding: utf-8 -*-
import os
import sys
import time
import socket
import ssl
import subprocess
from concurrent.futures import ThreadPoolExecutor

# Пробуем импортировать requests
try:
    import requests
    # Отключаем предупреждения об отсутствии SSL-валидации (verify=False)
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
    HAS_REQUESTS = True
except ImportError:
    HAS_REQUESTS = False

TARGET_URLS = [
    "https://www.youtube.com",
    "https://rr1---sn-axq7sn7s.googlevideo.com"
]

# --- МЕТОД 1: Системный вызов curl.exe ---
def test_via_curl(url):
    cmd = f'curl -I -s -k --max-time 5 "{url}"'
    start_time = time.time()
    try:
        res = subprocess.run(cmd, shell=True, capture_output=True, text=True)
        success = (res.returncode == 0 and "HTTP/" in res.stdout)
    except Exception:
        success = False
    elapsed = (time.time() - start_time) * 1000
    return success, elapsed

# --- МЕТОД 2: Библиотека requests (Python) ---
def test_via_requests(url):
    if not HAS_REQUESTS:
        return False, 0.0
    start_time = time.time()
    try:
        # verify=False аналогичен флагу -k в curl
        r = requests.get(url, timeout=5.0, verify=False, headers={'User-Agent': 'Mozilla/5.0'})
        success = (r.status_code in [200, 403, 404, 301, 302])
    except Exception:
        success = False
    elapsed = (time.time() - start_time) * 1000
    return success, elapsed

# --- МЕТОД 3: Нативный SSL-сокет (Winsock) ---
def test_via_native_ssl(url):
    host = url.split("://")[1].split("/")[0]
    start_time = time.time()
    try:
        ip = socket.gethostbyname(host)
        context = ssl.create_default_context()
        context.check_hostname = False
        context.verify_mode = ssl.CERT_NONE
        
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(5.0)
        
        conn = context.wrap_socket(s, server_hostname=host)
        conn.connect((ip, 443))
        conn.close()
        success = True
    except Exception:
        success = False
    elapsed = (time.time() - start_time) * 1000
    return success, elapsed

def run_experiment():
    print("="*60)
    print("    СТАРТ СЕТЕВОГО ЭКСПЕРИМЕНТА И БЕНЧМАРКИНГА")
    print("="*60)
    print("[!] Убедитесь, что у вас запущен рабочий обход (custom_generated.bat)")
    print("[*] Выполняется тестирование методов доступа...")

    # 1. Тест метода curl.exe
    print("\n[*] Тестирование метода 1: Системный вызов curl.exe...")
    curl_times = []
    with ThreadPoolExecutor(max_workers=2) as executor:
        futures = [executor.submit(test_via_curl, url) for url in TARGET_URLS]
        for idx, f in enumerate(futures):
            success, elapsed = f.result()
            curl_times.append(elapsed)
            status = "УСПЕШНО" if success else "СБОЙ/ТАЙМАУТ"
            print(f"    -> {TARGET_URLS[idx]:42} : {status} за {elapsed:.1f} мс")

    # 2. Тест метода requests
    if HAS_REQUESTS:
        print("\n[*] Тестирование метода 2: Библиотека requests (Python)...")
        req_times = []
        with ThreadPoolExecutor(max_workers=2) as executor:
            futures = [executor.submit(test_via_requests, url) for url in TARGET_URLS]
            for idx, f in enumerate(futures):
                success, elapsed = f.result()
                req_times.append(elapsed)
                status = "УСПЕШНО" if success else "СБОЙ/ТАЙМАУТ"
                print(f"    -> {TARGET_URLS[idx]:42} : {status} за {elapsed:.1f} мс")
    else:
        print("\n[!] Метод 2 пропущен: библиотека requests не установлена.")

    # 3. Тест нативного SSL-сокета
    print("\n[*] Тестирование метода 3: Нативный SSL-сокет (Winsock)...")
    sock_times = []
    with ThreadPoolExecutor(max_workers=2) as executor:
        futures = [executor.submit(test_via_native_ssl, url) for url in TARGET_URLS]
        for idx, f in enumerate(futures):
            success, elapsed = f.result()
            sock_times.append(elapsed)
            status = "УСПЕШНО" if success else "СБОЙ/ТАЙМАУТ"
            print(f"    -> {TARGET_URLS[idx]:42} : {status} за {elapsed:.1f} мс")

    # Сравнение средних результатов
    print("\n" + "="*60)
    print("    ИТОГИ СРАВНЕНИЯ СКОРОСТИ (СРЕДНЕЕ ВРЕМЯ)")
    print("="*60)
    print(f"    - Метод 1 (curl.exe)    : {sum(curl_times)/len(curl_times):.1f} мс")
    if HAS_REQUESTS:
        print(f"    - Метод 2 (requests)    : {sum(req_times)/len(req_times):.1f} мс")
    print(f"    - Метод 3 (Нативный SSL): {sum(sock_times)/len(sock_times):.1f} мс")
    print("="*60)

if __name__ == "__main__":
    run_experiment()
