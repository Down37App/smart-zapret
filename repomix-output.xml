def parse_strategies_from_bat(bat_path):
    """Считывает лучшую рабочую конфигурацию прямо из сгенерированного .bat файла."""
    yt_cmd = "--dpi-desync=disorder --dpi-desync-split-pos=midsld --dpi-desync-fooling=badseq"
    ds_cmd = "--dpi-desync=disorder --dpi-desync-split-pos=sniext --dpi-desync-fooling=badseq"
    try:
        if os.path.exists(bat_path):
            with open(bat_path, "r", encoding="utf-8", errors="ignore") as f:
                content = f.read()
            # Извлекаем стратегию YouTube
            yt_match = re.search(r'--hostlist="%LISTS%list-google\.txt" --ip-id=zero (.*?)(?:--new|\n|\^)', content)
            if yt_match:
                yt_cmd = yt_match.group(1).replace("^", "").strip()
            # Извлекаем стратегию Discord
            ds_match = re.search(r'--hostlist="%LISTS%list-discord\.txt" (.*?)(?:--new|\n|\^)', content)
            if ds_match:
                ds_cmd = ds_match.group(1).replace("^", "").strip()
    except: pass
    return yt_cmd, ds_cmd

