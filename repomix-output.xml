        cached = load_vless_cache()
        if cached:
            print(f"[!] Списки Reality недоступны. Загружен прокси из кэша: {cached['host']} ({cached.get('country', 'Неизвестно')})")
            return cached
        return None

    links = re.findall(r"vless://[^\s]+", content)
    if not links: return None

    candidate_servers = []
    for vless_link in links:
        vless_link = urllib.parse.unquote(vless_link)
        pattern = r"vless://([^@]+)@([^:]+):(\d+)\?([^#]+)"
        match = re.search(pattern, vless_link)
        if not match: continue
        query_str = match.group(4)
        params = urllib.parse.parse_qs(query_str)
        network_type = params.get("type", ["tcp"])[0]
        header_type = params.get("headerType", ["none"])[0]
        path = params.get("path", ["/"])[0]
        service_name = params.get("serviceName", [""])[0]
        security = params.get("security", ["none"])[0]
        flow = params.get("flow", [""])[0]
        if not flow and network_type == "tcp": flow = "xtls-rprx-vision"
        
        candidate_servers.append({
            "uuid": match.group(1), "host": match.group(2), "port": int(match.group(3)),
            "sni": params.get("sni", [""])[0], "pbk": params.get("pbk", [""])[0],
            "sid": params.get("sid", [""])[0], "fp": params.get("fp", ["chrome"])[0],
            "network_type": network_type, "header_type": header_type,
            "path": path, "service_name": service_name, "security": security, "flow": flow, "latency": 9999.0
        })

    print(f"[*] Запуск быстрого пинга {len(candidate_servers)} серверов подписки...")
    working_servers = []
    with ThreadPoolExecutor(max_workers=len(candidate_servers)) as executor:
        futures = [executor.submit(test_vless_latency, s) for s in candidate_servers]
        for f in futures:
            res = f.result()
            if res: working_servers.append(res)

    if not working_servers: return None
    working_servers.sort(key=lambda x: x["latency"])

    # Ищем быстрейший европейский сервер
    for s in working_servers[:10]:
        country, city = get_ip_country_and_provider(s["host"])
        if any(k in country.lower() for k in EUROPE_KEYWORDS):
            s["country"], s["city"] = country, city
            print(f"[+] Выбран европейский сервер: {s['host']} ({country}, Пинг: {s['latency']:.1f} мс)")
            save_vless_cache(s)
            return s
    # Фолбэк
    winner = working_servers[0]
    winner["country"], winner["city"] = get_ip_country_and_provider(winner["host"])
    save_vless_cache(winner)
    return winner

def write_xray_config(config_path, server, socks_port, http_port):
    stream_settings = {"network": server["network_type"], "security": server["security"]}
    if server["security"] == "reality":
        stream_settings["realitySettings"] = {
            "show": False, "fingerprint": server["fp"], "serverName": server["sni"],
            "publicKey": server["pbk"], "shortId": server["sid"], "spiderX": ""
        }
    elif server["security"] == "tls":
        stream_settings["tlsSettings"] = {"serverName": server["sni"], "fingerprint": server["fp"], "allowInsecure": True}
    
    if server["network_type"] == "grpc":
        stream_settings["grpcSettings"] = {"serviceName": server["service_name"]}
    elif server["network_type"] == "ws":
        stream_settings["wsSettings"] = {"path": server["path"], "headers": {}}

    user_entry = {"id": server["uuid"], "encryption": "none", "level": 0}
    if server["security"] in ["tls", "reality"] and server["network_type"] == "tcp" and server["flow"]:
        user_entry["flow"] = server["flow"]

    config_data = {
        "log": {"access": "", "error": "", "loglevel": "warning"},
        "inbounds": [
            {"listen": "127.0.0.1", "port": socks_port, "protocol": "socks", "settings": {"auth": "noauth", "udp": True, "ip": "127.0.0.1"}},
            {"listen": "127.0.0.1", "port": http_port, "protocol": "http", "settings": {"timeout": 360}}
        ],
        "outbounds": [{"protocol": "vless", "settings": {"vnext": [{"address": server["host"], "port": server["port"], "users": [user_entry]}]}, "streamSettings": stream_settings}]
    }
    with open(config_path, "w", encoding="utf-8") as f:
        json.dump(config_data, f, ensure_ascii=False, indent=2)

